# Environment & App Configuration
ENVIRONMENT=development
LOG_LEVEL=INFO
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","http://localhost"]

# Database Configuration
POSTGRES_SERVER=postgres
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_this_to_a_secure_password
POSTGRES_DB=software_reliability
DATABASE_URL=postgresql+psycopg2://postgres:change_this_to_a_secure_password@postgres:5432/software_reliability

# Security & Authentication
SECRET_KEY=generate_a_secure_random_key_with_openssl_rand_hex_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Firebase Integration
FIREBASE_PROJECT_ID=softwarereliability
FIREBASE_SERVICE_ACCOUNT_PATH=firebase-service-account.json

# Monitoring & Error Tracking (Optional)
SENTRY_DSN=
RATE_LIMIT_PER_MINUTE=100
